template build_location_entry {
	# icon
	hbox = {
		# Goods Icon
		layoutpolicy_vertical = expanding
		background = {
			using = color_production_texture
		}
		card_header_button_04 = {
			layoutpolicy_vertical = expanding
			size = { 45 -1 } # GlorpUI: 50->45

			enabled = "[ObjectsEqual(LocationToBuildItem.GetBuilding.GetOwner, Player.Self)]"
			tooltip_enabled = no

			piechart = {
				visible = "[LocationToBuildItem.HasBuilding]"
				using = bg_circle_piechart
				size = { 35 35 }
				datacontext = "[LocationToBuildItem.GetBuilding]"
				using = piechart_angles
				parentanchor = center

				using = building_employment_piechart_data
			}

			button = {
				visible = "[Not(ObjectsEqual(LocationToBuildItem.GetBuilding.GetOwner, Player.Self))]"
				size = { 100% 100% }
				icon = {
					size = { 30 30 }
					parentanchor = center
					texture = "[GetBuildingIcon(BuildInLocationLateralView.GetBuildingType)]"
				}
				enabled = "[ObjectsEqual(LocationToBuildItem.GetBuilding.GetOwner, Player.Self)]"
				datacontext = "[BuildInLocationLateralView.GetBuildingType]"

				tooltipwidget = {
					using = BuildingType_tooltip
					blockoverride "production_method_simple_good_tooltip" {
						datacontext = "[LocationToBuildItem.GetLocation.GetMarket]"
						tooltipwidget = {
							using = SpecificGoodsMarket_tooltip
						}
					}
				}
			}

			button = {
				visible = "[LocationToBuildItem.HasBuilding]"
				size = { 100% 100% }
				parentanchor = center
				icon = {
					texture = "[GetBuildingIcon(BuildInLocationLateralView.GetBuildingType)]"
					size = { 30 30 }
					parentanchor = center
				}
				enabled = "[ObjectsEqual(LocationToBuildItem.GetBuilding.GetOwner, Player.Self)]"

				datacontext = "[LocationToBuildItem.GetBuilding]"

				action_tooltip = {
					click_mode = single
					click_type = left
					title = "BUILD_LOCATION_GOTO_BUILDING_PANEL"
					enabled = "[ObjectsEqual(LocationToBuildItem.GetBuilding.GetOwner, Player.Self)]"
					on_action = "[OpenBuildingView(LocationToBuildItem.GetBuilding)]"
				}

				tooltipwidget = {
					using = Building_tooltip
				}
			}

			icon = {
				size = { 15 15 }
				position = { -2 -2 }
				parentanchor = top|left
				using = warning_icon_texture
				visible = "[LessThan_CFixedPoint(LocationToBuildItem.GetBuilding.GetInputGoodsAccess,'(CFixedPoint)1.0')]"
				using = bg_circle
			}
		}
	}

	vbox = {
		layoutpolicy_horizontal = expanding
		widget = {
			layoutpolicy_horizontal = expanding
			size = { -1 46 }

			widget = {
				size = { 100% 46 }
				using = bg_paper_card
				parentanchor = center

				hbox = {
					layoutpolicy_horizontal = expanding
					margin = { 0 0 }

					hbox = {
						# Location + Population Info
						background = {
							using = color_intense_brown_texture
							modify_texture = {
								texture = "[GetGraphicalCultureTexture('header_pattern')]"
								texture_density = 2
								spriteType = corneredtiled
								blend_mode = overlay
								alpha = 0.2
							}

							modify_texture = {
								using = overlay_cloth_texture
								blend_mode = overlay
								alpha = 0.1
							}
						}
						card_header_button_04 = {
							size = { 220 46 } # GlorpUI: {160 43} -> {220 46}

							hbox = {
								layoutpolicy_horizontal = expanding
								margin_right = 0
								vbox = {
									maximumsize = { 160 46 }
									layoutpolicy_horizontal = expanding
									margin = { 5 3 }
									margin_right = 0
									spacing = 4

									hbox = {
										#top text
										layoutpolicy_horizontal = expanding
										spacing = 3

										widget = {
											# Glorp UI - Replace Location Icon w/ Clickable Upgrade Button
											size = { 15 15 }

											button = {
												size = { 100% 100% }
												position = { 0 0 }

												action_tooltip = {
													click_type = left
													click_mode = confirm
													enabled = "[Location.CanUpgradeRank]"
													title = "[Location.GetUpgradeRankName]"
													cost = "[Location.GetUpgradeRankPrice]"
													description = "[Location.GetUpgradeRankDescription]"
													effects = "[Location.GetUpgradeRankEffects]"
													conditions = "[Location.GetUpgradeRankConditions]"
													on_action = "[UpgradeLocationRank(Location.Self)]"
												}

												action_tooltip = {
													click_type = right
													click_mode = confirm
													enabled = "[Location.CanDowngradeRank]"
													title = "location_downgrade"
													cost = "[Location.GetDowngradeRankPrice]"
													description = "[Location.GetDowngradeRankDescription]"
													effects = "[Location.GetDowngradeRankEffects]"
													conditions = "[Location.GetDowngradeRankConditions]"
													on_action = "[DowngradeLocationRank(Location.Self)]"
												}

												enabled = "[Or(Location.CanUpgradeRank, Location.CanDowngradeRank)]"

												tooltipwidget = {
													using = location_rank_tooltip
													blockoverride "location_rank_tooltip_button" {
														TooltipBlockList = {
															visible = "[Not(StringIsEmpty(Location.GetUpgradeRankPriceBreakdown))]"
															textcontext = "[Location.GetUpgradeRankPriceBreakdown]"
														}
													}
												}

												icon = {
													size = { 100% 100% }
													parentanchor = center
													position = { 0 0 }
													texture = "[Location.GetRankIcon]"

													glow = {
														visible = "[Location.CanUpgradeRank]"
														glow_radius = 3
														color = { 0.3 1.0 0.3 1.0 }
														alpha = 0.6
													}
												}
											}
										}

										text_single = {
											visible = "[IsDataModelEmpty(Location.GetCivilConstructions)]"
											maximumsize = { 120 15 }
											alwaystransparent = no
											align = left|nobaseline
											autoresize = yes
											using = Font_Size_Small
											text = "[LocationToBuildItem.GetLocation.GetNameWithNoTooltip]"
											default_format = "#yellow_titles"

											sort_by_left_fade_highlight = {
												size = { 200% 170% }
												position = { 40 0 }
												name = "name"
											}
										}

										text_single = {
											visible = "[Not(IsDataModelEmpty(Location.GetCivilConstructions))]"
											maximumsize = { 105 15 }
											alwaystransparent = no
											align = left|nobaseline
											autoresize = yes
											using = Font_Size_Small
											text = "[LocationToBuildItem.GetLocation.GetNameWithNoTooltip]"
											default_format = "#yellow_titles"

											sort_by_left_fade_highlight = {
												size = { 200% 170% }
												position = { 40 0 }
												name = "name"
											}
										}

										text_single = {
											datacontext = "[LocationToBuildItem.GetLocation]"
											visible = "[Not(IsDataModelEmpty(Location.GetCivilConstructions))]"
											size = { 30 15 }
											alwaystransparent = no
											align = left|nobaseline
											autoresize = no
											using = Font_Size_Small

											raw_text = "#L +[GetDataModelSize(Location.GetCivilConstructions)]#! @construction!"

											hbox = {
												datamodel = "[DataModelFirst(Location.GetCivilConstructions,'(int32)1')]"
												item = {
													hbox = {
														using = layoutpolicy_expanding
														tooltipwidget = {
															using = Construction_tooltip
														}
													}
												}
											}
										}

										expand = { }
									}

									hbox = {
										#bottom
										datacontext = "[LocationToBuildItem.GetLocation]"
										layoutpolicy_horizontal = expanding
										spacing = 0
										margin = { 0 0 }
										margin_right = 0

										hbox = {
											# Glorp UI - Building Limit and RGO
											button = {
												size = { 20 20 }

												action_tooltip = {
													click_type = left
													click_mode = single
													title = "OPEN_GOOD_PANEL"
													on_action = "[ShowGoods(LocationToBuildItem.GetLocation.GetRawMaterial)]"
												}
												texture = "[GetGoodsIcon(LocationToBuildItem.GetLocation.GetRawMaterial)]"

												datacontext = "[LocationToBuildItem.GetLocation.GetRawMaterial]"
												datacontext = "[LocationToBuildItem.GetLocation.GetOwner]"
												datacontext = "[LocationToBuildItem.GetLocation.GetMarket]"
												tooltipwidget = { using = SpecificGoodsMarket_tooltip }
											}
											button = {
												size = { 20 20 }
												icon = {
													size = { 18 18 }
													texture = "gfx/interface/icons/outliner/categories/buildings.dds"
												}
												datacontext = "[LocationToBuildItem.GetLocation]"
												tooltipwidget = {
													using = LocationBuildingLevels_tooltip
												}
												action_tooltip = {
													click_type = left
													click_mode = single
													title = "GO_TO_LOCATION"
													on_action = "[ShowLocation(LocationToBuildItem.GetLocation)]"
												}

												progressbar = {
													parentanchor = right
													visible = "[Not(LocationToBuildItem.GetLocation.HasTooManyBuildingLevel)]"
													size = { 4 20 }
													using = progress_bar_green_alt
													min = 0
													max = 100
													value = "[LocationToBuildItem.GetLocation.GetBuildingLevelsPercentage]"
													direction = vertical
												}
												progressbar = {
													parentanchor = right
													visible = "[LocationToBuildItem.GetLocation.HasTooManyBuildingLevel]"
													size = { 4 20 }
													using = progress_bar_red_alt
													min = 0
													max = 100
													value = 100
													direction = vertical
												}
											}
										}
										expand = { }

										hbox = {
											datacontext = "[LocationToBuildItem.GetBuildingType.GetPopType]"

											hbox = {
												spacing = 3
												layoutpolicy_vertical = expanding
												text_single = {
													layoutpolicy_vertical = expanding
													maximumsize = { 60 -1 }
													align = center|nobaseline
													autoresize = yes
													fontsize = 15
													text = "[Location.GetExpectedUnEmployed(PopType.Self)]"
													sort_by_highlight = {
														size = { 105% 200% }
														name = "employment"
													}
												}
												icon = {
													size = { 15 15 }
													texture = "[GetGraphicalCultureTextureForCountryPopType(PopType.Self, Location.GetOwner.Self)]"
												}

												tooltipwidget = {
													using = locationview_employed_tt
												}
											}
										}

										expand = { }

										hbox = {
											layoutpolicy_vertical = expanding
											visible = "[And(Not(LocationToBuildItem.GetBuildingType.GetPopType.IsPeasant), Not(LocationToBuildItem.GetBuildingType.GetPopType.IsSlaves))]"
											spacing = 3
											text_single = {
												layoutpolicy_vertical = expanding
												maximumsize = { 60 -1 }
												align = center|nobaseline
												fontsize = 15
												autoresize = yes
												text = "[GetUnEmployedPeasantsFromLocation(LocationToBuildItem.GetLocation)]"
												sort_by_highlight = {
													size = { 105% 200% }
													name = "population"
												}
											}
											icon = {
												size = { 15 15 }
												texture = "gfx/interface/icons/pops/peasants.dds"
											}

											tooltipwidget = {
												using = available_peasants_tooltip
											}
										}

									}
								}

								# Glorp UI - Market Access (or Terrain Bonus when constructing a fort), Control
								vbox = {
									maximumsize = { 60 46 }
									layoutpolicy_horizontal = expanding
									hbox = {
										# Market Access
										visible = "[Not(GetScriptedGui('glorpui_building_type_is_defense_category').IsShown(GuiScope.SetRoot(BuildInLocationLateralView.GetBuildingType.MakeScope).End))]"
										piechart = {
											size = { 20 20 }
											alwaystransparent = yes
											datacontext = "[GetMapMode('market')]"
											datacontext = "[LocationToBuildItem.GetLocation.GetMarket]"

											using = piechart_angles
											pieslice_no_highlight = {
												texture = "gfx/interface/pie_charts/pie_chart_alpha_80_green.dds"
												value = "[FixedPointToFloat(LocationToBuildItem.GetLocation.GetMarketAccess)]"
												color = { 1 1 1 1 }
												alwaystransparent = yes
											}

											pieslice_no_highlight = {
												texture = "gfx/interface/pie_charts/pie_chart_alpha_80_red.dds"
												value = "[Subtract_float('(float)1.0', FixedPointToFloat(LocationToBuildItem.GetLocation.GetMarketAccess))]"
												color = { 1 1 1 1 }
												alwaystransparent = yes
											}

											icon = {
												size = { 61% 61% }
												parentanchor = center
												texture = "gfx/interface/icons/location_icons/market.dds"
											}

											using = bg_circle_piechart
											button = {
												# Tooltip + Action
												parentanchor = center
												size = { 100% 100% }
												tooltipwidget = {
													using = location_market_tooltip
												}
												action_tooltip = {
													click_type = left
													click_mode = single
													title = "OPEN_MARKET"
													on_action = "[ShowMarket(LocationToBuildItem.GetLocation.GetMarket.Self)]"
												}
												action_tooltip = {
													click_type = right
													click_mode = single
													title = "MAPMODE_SELECT"
													on_action = "[MapMode.SetMapMode]"
												}
											}
										}
										text_single = {
											size = { 30 18 }
											align = nobaseline|right
											autoresize = no
											fontsize = 14
											raw_text = "[LocationToBuildItem.GetLocation.GetMarketAccess|0%]"
										}
									}
									hbox = {
										# Terrain Attacker Penalty (when constructing a fort)
										visible = "[GetScriptedGui('glorpui_building_type_is_defense_category').IsShown(GuiScope.SetRoot(BuildInLocationLateralView.GetBuildingType.MakeScope).End)]"
										datacontext = "[LocationToBuildItem.GetLocation]"
										widget = {
											size = { 20 20 }
											using = bg_circle_piechart
											background = {
												texture = "[GetClimateFrame(Location.GetClimate)]"
												alpha = 0.6
											}
											icon = {
												size = { 70% 70% }
												parentanchor = center
												texture = "[GetTopographyIcon(Location.GetTopography)]"
											}
											button = {
												parentanchor = center
												size = { 100% 100% }
												tooltipwidget = {
													SimpleContextualStringPairTooltipType = {
														blockoverride "title_icon" {
															icon = {
																using = tooltip_title_icon_size
																texture = "gfx/interface/icons/modifier_types/fort_level.dds"
															}
														}
														blockoverride "concept_link" {
															text = "[fort|e]"
														}
														lowpriotextcontext = "[JoinText(Localize('line_break'), Localize('TERRAIN_ATTACKER_PENALTY_TT'), Location.GetFortInfo)]"
													}
												}
											}
										}
										text_single = {
											size = { 30 18 }
											align = nobaseline|right
											autoresize = no
											fontsize = 14
											raw_text = "[Location.GetAttackerPenalty|-=]"
										}
									}
									hbox = {
										# Control
										piechart = {
											name = "location_control"
											using = bg_circle
											size = { 20 20 }
											datacontext = "[LocationToBuildItem.GetLocation]"
											tooltipwidget = {
												using = location_control_tooltip
												blockoverride "location_control_widgetid" {
													widgetid = "location_control_tooltip_id"
												}
											}
											using = piechart_angles

											pieslice_no_highlight = {
												texture = "gfx/interface/pie_charts/pie_chart_alpha_80_green.dds"
												value = "[FixedPointToFloat(LocationToBuildItem.GetLocation.GetControl)]"
												color = { 1 1 1 1 }
												alwaystransparent = yes
											}

											pieslice_no_highlight = {
												texture = "gfx/interface/pie_charts/pie_chart_alpha_80_red.dds"
												value = "[Subtract_float('(float)1.0', FixedPointToFloat(LocationToBuildItem.GetLocation.GetControl))]"
												color = { 1 1 1 1 }
												alwaystransparent = yes
											}

											icon = {
												size = { 60% 60% }
												parentanchor = center
												texture = "gfx/interface/icons/location_icons/control.dds"
											}

											using = bg_circle_piechart

											button = {
												# Tooltip + Action
												size = { 100% 100% }
												datacontext = "[GetMapMode('control')]"
												datacontext = "[LocationToBuildItem.GetLocation]"
												tooltipwidget = {
													using = location_control_tooltip
													blockoverride "location_control_widgetid" {
														widgetid = "location_control_tooltip_id"
													}
												}
												action_tooltip = {
													click_type = left
													click_mode = single
													title = "MAPMODE_SELECT"
													on_action = "[MapMode.SetMapMode]"
												}
											}
										}
										text_single = {
											size = { 30 18 }
											align = nobaseline|right
											autoresize = no
											fontsize = 14
											raw_text = "[LocationToBuildItem.GetLocation.GetControl|0%]"
										}
									}
								}
							}

							action_tooltip = {
								click_type = left
								click_mode = single
								title = "GO_TO_LOCATION"
								on_action = "[ShowLocation(LocationToBuildItem.GetLocation)]"
							}
							action_tooltip = {
								click_type = right
								click_mode = single

								cursor = "location_menu"
								title = "CLICK_ACTION_LOCATION_CONTEXT_MENU"
								on_action = "[PdxGuiWidget.ToggleContextMenu]"
							}
							ondoubleclick = "[PanToLocation(LocationToBuildItem.GetLocation)]"
							onmousehierarchyenter = "[PdxGuiWidget.SetHighlightLocation(LocationToBuildItem.GetLocation)]"

							datacontext = "[LocationToBuildItem.GetLocation]"
							tooltipwidget = {
								using = location_simple_tooltip
							}
							contextmenu_widget = {
								LocationContextMenu = { }
							}
						}
					}

					# LSQ auto-expand button
					lsq_auto_expand_widget_global_construction = { }

					widget = {
						#subsidize/close
						size = { 23 46 }
						vbox = {
							spacing = 0
							button_square_checkbox = {
								visible = "[And(ObjectsEqual(LocationToBuildItem.GetBuilding.GetOwner, Player.Self), LocationToBuildItem.GetBuilding.GetType.IsProducing)]"
								size = { 23 23 }
								enabled = "[CanSubsidizeBuilding(LocationToBuildItem.GetBuilding.Self)]"

								blockoverride "check_texture" {
									texture = "gfx/interface/icons/flat_icons/building_panel/subsidized.dds"
								}
								blockoverride "checked_visible" {
									visible = "[LocationToBuildItem.GetBuilding.IsSubsidized]"
								}
								blockoverride "unchecked_visible" {
									visible = "[Not(LocationToBuildItem.GetBuilding.IsSubsidized)]"
								}
								background = {
									texture = "gfx/interface/buttons/checkbox_bg_square.dds"
									texture_density = 2

									modify_texture = {
										using = color_market_grey_texture
										blend_mode = add
										alpha = 0.5
									}
								}

								action_tooltip = {
									click_type = left
									title = "[SelectLocalization( LocationToBuildItem.GetBuilding.IsSubsidized, 'TOGGLE_SUBSIDIZE_ON', 'TOGGLE_SUBSIDIZE_OFF' )]"
									enabled = "[CanSubsidizeBuilding(LocationToBuildItem.GetBuilding.Self)]"
									description = "[GetSubsidizeBuildingInfo(LocationToBuildItem.GetBuilding.Self)]"
									on_action = "[SubsidizeBuilding(LocationToBuildItem.GetBuilding.Self)]"
									on_action = "[PlayAudioEffect(Concatenate('UI_action_building_subsidize', GetToggleSuffix(Building.IsSubsidized)))]"
								}

								action_tooltip = {
									click_type = right
									title = "TOGGLE_SUBSIDIZE_ALL_BUILDINGS"
									enabled = "[CanSubsidizeBuilding(LocationToBuildItem.GetBuilding.Self)]"
									on_action = "[BuildInLocationLateralView.SubsidizeAllBuildings]"
									on_action = "[PlayAudioEffect(Concatenate('UI_action_building_subsidize', GetToggleSuffix(Building.IsSubsidized)))]"
								}

								datacontext = "[LocationToBuildItem.GetBuilding]"

								tooltipwidget = {
									using = Location_Building_Subsidized_Tooltip
								}
							}

							button_square_checkbox = {
								size = { 23 23 }
								enabled = "[CanToggleBuilding(Building.Self)]"
								visible = "[ObjectsEqual(LocationToBuildItem.GetBuilding.GetOwner, Player.Self)]"
								datacontext = "[LocationToBuildItem.GetBuilding]"
								tooltipwidget = {
									using = Location_Building_Open_Tooltip
								}
								blockoverride "check_texture" {
									texture = "gfx/interface/icons/achievements/padlock.dds"
								}
								blockoverride "checked_visible" {
									visible = "[Not(LocationToBuildItem.GetBuilding.IsOpen)]"
								}
								blockoverride "unchecked_visible" {
									visible = "[LocationToBuildItem.GetBuilding.IsOpen]"
								}
								background = {
									texture = "gfx/interface/buttons/checkbox_bg_square.dds"
									texture_density = 2

									modify_texture = {
										using = color_market_grey_texture
										blend_mode = add
										alpha = 0.5
									}
								}

								action_tooltip = {
									click_type = left
									title = "[SelectLocalization(Building.IsOpen, 'TOGGLE_CLOSE_ON', 'TOGGLE_CLOSE_OFF' )]"
									enabled = "[CanToggleBuilding(Building.Self)]"
									description = "[GetToggleBuildingInfo(Building.Self)]"
									on_action = "[ToggleBuilding(Building.Self)]"
								}

								action_tooltip = {
									click_type = right
									title = "TOGGLE_CLOSE_ALL_BUILDINGS"
									enabled = "[CanToggleBuilding(Building.Self)]"
									on_action = "[BuildInLocationLateralView.ToggleCloseAllBuildings]"
								}
							}
						}

						vbox = {
							visible = "[And(LocationToBuildItem.IsForeignBuilding, LocationToBuildItem.GetLocation.GetOwner.IsValid)]"
							spacing = 2

							icon = {
								visible = "[Not(BuildInLocationLateralView.GetBuildingType.IsForeign)]"
								datacontext = "[LocationToBuildItem.GetLocation.GetOwner]"
								size = { 20 20 }
								texture = "[GetSubjectTypeIcon(Country.GetDiplomacy.GetSubjectType)]"

								tooltipwidget = {
									using = SubjectTypeDetail_tooltip
								}

								alpha = 0.8
								using = bg_circle_piechart
								blockoverride "inside_color" {
									modify_texture = {
										using = color_bg_blue_texture
										blend_mode = multiply
									}
								}
								blockoverride "frame_color" {
									modify_texture = {
										using = color_new_gold_texture
										blend_mode = multiply
									}
									modify_texture = {
										using = color_gold_texture
										# blend_mode = multiply
										alpha = 0.5
									}
								}

								glow = {
									name = "drop_shadow"
									glow_radius = 3
									color = { 0.0 0.0 0.0 1.0 }
									alpha = 0.3
								}
							}

							country_flag_very_small = {
								datacontext = "[LocationToBuildItem.GetLocation.GetOwner]"
							}
						}
					}

					# expand = {}

					hbox = {
						# Profits, Efficiencies, Build Buttons
						datacontext = "[LocationToBuildItem.GetLocation]"
						datacontext = "[LocationToBuildItem.GetBuilding]"

						hbox = {
							margin_right = 2
							spacing = 0
