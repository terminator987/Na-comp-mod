											size = { 25 25 }
											texture = "gfx/interface/icons/flat_icons/mass_upgrade.dds"
										}

										# LSQ mass auto-expand button
										lsq_mass_auto_expand_button_bll = {}

										text_single = {
											fontsize = 13
											layoutpolicy_horizontal = expanding
											autoresize = no
											align = center
											size = { -1 20 }
											text = "UPGRADING_BEST_IN_LOCATION_ACTION_BUTTON"
										}
									}
								}

								action_tooltip = {
									click_type = left
									click_mode = single
									click_modifier = default

									title = "UPGRADE_IN_BEST_LOCATION_ACTION"
									cost = "[GetBuildOrExpandBuildingCostValue(BuildingType.Self, Location.Self)]"
									description = "[CanUpgradeToBuildingInfo(BuildingType.Self, Location.Self)]"
									on_action = "[BuildInLocationLateralView.BuildBestFromRankingItemsDefault]"
									enabled = "[CanUpgradeToBuilding(BuildingType.Self, Location.Self)]"
								}

								action_tooltip = {
									click_type = left
									click_mode = single
									click_modifier = ctrl

									title = "UPGRADE_IN_BEST_LOCATION_ACTION_CTRL"
									cost = "[GetBuildOrExpandBuildingCostValue(BuildingType.Self, Location.Self)]"
									description = "[CanUpgradeToBuildingInfo(BuildingType.Self, Location.Self)]"
									on_action = "[BuildInLocationLateralView.BuildBestFromRankingItemsCtrl]"
									enabled = "[CanUpgradeToBuilding(BuildingType.Self, Location.Self)]"
								}

								action_tooltip = {
									click_type = left
									click_mode = single
									click_modifier = shift

									title = "UPGRADE_IN_BEST_LOCATION_ACTION_SHIFT"
									cost = "[GetBuildOrExpandBuildingCostValue(BuildingType.Self, Location.Self)]"
									description = "[CanUpgradeToBuildingInfo(BuildingType.Self, Location.Self)]"
									on_action = "[BuildInLocationLateralView.BuildBestFromRankingItemsShift]"
									enabled = "[CanUpgradeToBuilding(BuildingType.Self, Location.Self)]"
								}

								tooltipwidget = {
									using = upgrade_building_ranking_tt
								}
							}
						}

						#CAN NOT BUILD
						widget = {
							layoutpolicy_horizontal = expanding
							size = { -1 40 }
							visible = "[Not(BuildInLocationLateralView.HasBestBuildLocationItem)]"
							header_button_right = {
								size = { 100% 100%}
								visible = "[Not(Player.CanUpgradeBuildingType(BuildInLocationLateralView.GetBuildingType))]"

								enabled = no
								datacontext = "[BuildInLocationLateralView.GetBuildRankingItems]"
								datacontext = "[BuildInLocationLateralView.GetBuildingType]"

								blockoverride "icon_overlay" {}
								blockoverride "icon_texture" {
									visible = no
								}

								blockoverride "header_button_text_layout" {
									hbox = {
										using = layoutpolicy_expanding
										margin = { 5 0 }
										margin_left = 10

										icon = {
											size = { 25 25 }
											texture = "gfx/interface/icons/flat_icons/mass_construct.dds"
										}

