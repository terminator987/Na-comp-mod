									# 					texture = "[GetBuildingIcon(BuildInLocationLateralView.GetBuildingType.GetNextReplacementBuilding(Player.Self))]"
									# 				}
									# 			}
									# 			lowpriotextcontext = UPGRADE_LOCATION_NUMBER
									# 		}
									# 	}
