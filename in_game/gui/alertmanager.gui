										blockoverride "field_left" {}
										blockoverride "field_text" {
											default_format = "#subtle_name"
											align = left|nobaseline
											raw_text = "[UpgradeableBuildingTypeLevels.GetBuildingType.GetIcon] [UpgradeableBuildingTypeLevels.GetBuildingType.GetName]"
										}
										blockoverride "field_right" { expand = {} }
									}
									TooltipTableColumn = {
										blockoverride "column_title" { visible = no }
										blockoverride "column_title_text" { }
										blockoverride "field_left" { expand = {} }
										blockoverride "field_text" {
											tooltipwidget = { using = upgradeable_building_type_levels_breakdown_tooltip }
											text = "[UpgradeableBuildingTypeLevels.GetLevels|L]"
										}
									}
									blockoverride "column_datamodel" {
										datacontext = "[GetCountryUpgradeableBuildings(Player.Self)]"
										datamodel = "[MarketUpgradeableBuildings.GetBuildingTypeLevels]"
									}
								}
							}
						}
					}
				}
			}

			TooltipListBase = { #+3 Markets
				datacontext = "[GetCountryUpgradeableBuildings(Player.Self)]"
				visible = "[GreaterThan_int32(CountryUpgradeableBuildings.GetMarketUpgradeableBuildingsCount, '(int32)3' )]"
				TooltipScrolledContentSection = {
					blockoverride "block_scrollarea" { maximumsize = { -1 420 } }
					blockoverride "section_content" {
						TooltipListColumnContent = {
							TooltipTableColumn = {
								blockoverride "column_title" {}
								blockoverride "column_title_text" {
									text = "[market|e]"
								}
								blockoverride "column_title_right" {
									expand = {}
								}

								blockoverride "field_left" {
									visible = "[GreaterThan_int32(MarketUpgradeableBuildings.GetUpgradeableBuildingLevelsCount, '(int32)0')]"
								}

								blockoverride "field_text" {
									default_format = "#subtle_name"
									align = left|nobaseline
									raw_text = "@market! [MarketUpgradeableBuildings.GetMarket.GetName]"
								}

								blockoverride "field_right" { expand = {} }
							}

							TooltipTableColumn = {
								blockoverride "column_title" {}
								blockoverride "column_title_left" {
									expand = {}
								}
								blockoverride "column_title_text" {
									text = "MARKET_UPGRADEABLE_BUILDING_LEVELS_COLUMN"
								}

								blockoverride "field_text" { visible = no }
								blockoverride "field_right" {
									spacing = 7
									expand = {}
									visible = "[GreaterThan_int32(MarketUpgradeableBuildings.GetUpgradeableBuildingLevelsCount, '(int32)0')]"
									datacontext = "[MarketUpgradeableBuildings.GetMarket]"
									datacontext = "[GetMarketUpgradeableBuildings(Player.Self, Market.Self)]"
									tooltipwidget = { using = market_hub_upgradeable_buildings_tooltip }

									text_single = {
										visible = "[GreaterThan_int32(MarketUpgradeableBuildings.GetUpgradeableBuildingLevelsCount, '(int32)0')]"
										text = "[MarketUpgradeableBuildings.GetUpgradeableBuildingLevelsCount|L]"
									}

									text_single = {
										visible = "[Not(GreaterThan_int32(MarketUpgradeableBuildings.GetUpgradeableBuildingLevelsCount, '(int32)0'))]"
										raw_text = "-"
									}

									icon = {
										shaderfile = "gfx/FX/pdxgui_default.shader"
										size = {15 15}
										texture = "gfx/interface/icons/alerts_icons/upgradeable_buildings.dds"

										using = bg_banner_button_vertical

										blockoverride "banner_button_extra" {
											visible = "[MarketUpgradeableBuildings.HasUpgradeableBuildings]"
										}

										blockoverride "banner_button_color" {
											modify_texture = {
												visible = "[MarketUpgradeableBuildings.HasUpgradeableBuildings]"
												using = color_yellow_texture
												alpha = 0.6
											}
										}
									}
								}
							}

							blockoverride "column_datamodel"  {
								datacontext = "[GetCountryUpgradeableBuildings(Player.Self)]"
								datamodel = "[CountryUpgradeableBuildings.GetMarketUpgradeableBuildings]"
							}
						}
					}
				}
			}
		}
	}
}

