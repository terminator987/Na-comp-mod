						text = "ALERT_HAS_DISLOYAL_SUBJECTS"
					}

					TooltipListScrollArea = {
						blockoverride "block_scrollarea" {
							maximumsize = { -1 400 }
						}
						blockoverride "scrollarea_content" {
							fixedgridbox = {
								addcolumn = 420
								addrow = 30
								setitemsizefromcell = yes

								datamodel = "[AlertHasDisloyalSubjects.GetEntries]"
