template automatic_priority_alert {
	textcontext = "[AlertEntry.GetDescription.GetPriority]"
	button = {
		size = { 100% 100% }
		alwaystransparent = yes
		visible = "[AlertEntry.GetDescription.IsPriority('blue')]"
		using = blue_alert
	}

	button = {
		size = { 100% 100% }
		alwaystransparent = yes
		visible = "[AlertEntry.GetDescription.IsPriority('green')]"
		using = green_alert
	}

	button = {
		size = { 100% 100% }
		alwaystransparent = yes
		visible = "[AlertEntry.GetDescription.IsPriority('yellow')]"
		using = yellow_alert
	}

	button = {
		size = { 100% 100% }
		alwaystransparent = yes
		visible = "[AlertEntry.GetDescription.IsPriority('orange')]"
		using = orange_alert
	}

	button = {
		size = { 100% 100% }
		alwaystransparent = yes
		visible = "[AlertEntry.GetDescription.IsPriority('red')]"
		using = red_alert
	}

	button = {
		size = { 100% 100% }
		alwaystransparent = yes
		visible = "[AlertEntry.GetDescription.IsPriority('purple')]"
		using = purple_alert
	}
}

