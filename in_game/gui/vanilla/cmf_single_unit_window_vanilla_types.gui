				value = "[Combat.GetDefender.GetMoralePercent]"
				color = { 0.8 0.3 0.3 1 }
				alwaystransparent = yes
			}

			# ATTACKER SIDE
			pieslice_no_highlight = {
				texture = "gfx/interface/pie_charts/pie_chart_alpha_80.dds"
				value = "[Combat.GetAttacker.GetMoralePercent]"
