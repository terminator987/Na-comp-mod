				alpha = 1
			}
		}

		piechart = {
			visible = "[Siege.GetLocation.HasCombat]"
			parentanchor = center
			size = { 90% 90% }
			using = piechart_angles
			block "siegetooltip" {
				tooltipwidget = {
					using = SiegePhase_tooltip
				}
			}

			icon = {
				size = { 70% 70% }
				parentanchor = center
				tooltipwidget = {
					using = SiegeOutcome_tooltip
				}

				block "siege_progress_icon" {
