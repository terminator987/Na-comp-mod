		blockoverride "cabinet_entry_icon_piechart" {
			widget = {
				size = { 100% 100% }
				alwaystransparent = yes
				ignore_layout = yes
				background = {
					texture = "gfx/interface/buttons/checkbox_bg_round.dds"
					texture_density = 2
					using = button_outliner_effect
				}

				widget = {
					size = {100% 100%}
