# Available contexts
# "Outliner"
OutlinerEntryBase = {
	name = "market_entry"

	blockoverride "expanded_big_content" {
		OutlinerButtonBase = {
			size = { 95% 100% }

			hbox = {
				using = outliner_entry_margin
				spacing = 5

				# icon = {
				# 	size = { 18 18 }
				# 	texture = "[GetConceptTexture('market')]"
				# 	glow = {
				# 		name = "drop_shadow"
				# 		glow_radius = 3
				# 		color = {0.0 0.0 0.0 1.0}
				# 		alpha = 0.3
				# 	}
				# }

				icon = {
					visible = "[GreaterThan_CFixedPoint(Market.GetCountryPopulation(Player.Self),'(CFixedPoint)0')]"
					size = { 18 18 }
					texture = "[GetConceptTexture('domestic_market')]"
					glow = {
						name = "drop_shadow"
						glow_radius = 3
						color = {0.0 0.0 0.0 1.0}
						alpha = 0.3
					}
				}

				icon = {
					visible = "[And(Not(GreaterThan_CFixedPoint(Market.GetCountryPopulation(Player.Self),'(CFixedPoint)0')),
						GreaterThan_CFixedPoint(Market.GetTotalMerchantCapacity(Player.Self),'(CFixedPoint)0'))]"
					size = { 22 22 }
					texture = "[GetConceptTexture('trading_market')]"
					glow = {
						name = "drop_shadow"
						glow_radius = 3
						color = {0.0 0.0 0.0 1.0}
						alpha = 0.3
					}
				}

				icon = {
					visible = "[And(Not(Or(GreaterThan_CFixedPoint(Market.GetCountryPopulation(Player.Self),'(CFixedPoint)0'),
							GreaterThan_CFixedPoint(Market.GetTotalMerchantCapacity(Player.Self),'(CFixedPoint)0'))), IsMarketInRange(Market.Self))]"
					size = { 18 18 }
					texture = "[GetConceptTexture('foreign_market')]"
					glow = {
						name = "drop_shadow"
						glow_radius = 3
						color = {0.0 0.0 0.0 1.0}
						alpha = 0.3
					}
				}

				icon = {
					visible = "[And(Not(Or(GreaterThan_CFixedPoint(Market.GetCountryPopulation(Player.Self),'(CFixedPoint)0'),
							GreaterThan_CFixedPoint(Market.GetTotalMerchantCapacity(Player.Self),'(CFixedPoint)0'))), Not(IsMarketInRange(Market.Self)))]"
					size = { 18 18 }
					texture = "[GetConceptTexture('distant_market')]"
					glow = {
						name = "drop_shadow"
						glow_radius = 3
						color = {0.0 0.0 0.0 1.0}
						alpha = 0.3
					}
				}

				OutlinerTextBase = {
					visible = "[Not(GreaterThan_int32(Market.GetMerchantRanking(Player.Self), '(int32)0'))]"
					using = layoutpolicy_expanding
					autoresize = no
					align = left
					text = "[Market.GetShortNameWithNoTooltip]"
					default_format = "#L"
					fontsize = 14
				}
				OutlinerTextBase = {
					using = layoutpolicy_expanding
					visible = "[GreaterThan_int32(Market.GetMerchantRanking(Player.Self), '(int32)0')]"
					autoresize = no
					align = left
					raw_text = "[Market.GetShortNameWithNoTooltip] #medium ([Market.GetMerchantRanking(Player.Self)|O])#!"
					default_format = "#L"
					fontsize = 13
				}
				widget = {
					size = { 65 15 }
					hbox = {
						datacontext = "[GetMarketCountryNeeds(Player.Self, Market.Self)]"
						margin_right = 2
						expand = {}
						spacing = 7
						# icon = {
						# 	visible = "[GreaterThan_CFixedPoint(Market.GetMerchantAvailableCapacity(Player.Self),'(CFixedPoint)1.00')]"
						# 	size = {15 15}
						# 	texture = "gfx/interface/icons/flat_icons/trade_capacity.dds"

						# 	glow = {
						# 		name = "drop_shadow"
						# 		glow_radius = 3
						# 		color = {0.0 0.0 0.0 1.0}
						# 		alpha = 0.5
						# 	}

						# 	using = bg_banner_button_vertical

						# 	blockoverride "banner_button_color" {
						# 		modify_texture = {
						# 			using = color_yellow_texture
						# 			alpha = 0.6
						# 		}
						# 	}
						# 	datacontext = "[Player]"
						# 	tooltipwidget = {
						# 		using = merchant_capacity_tooltip
						# 	}
						# }

						icon = {
							size = {14 14}
							texture = "gfx/interface/icons/flat_icons/parliament_needs.dds"
							visible = "[Not(And(Not(MarketCountryNeeds.HasBuildingsMissingGoods), Not(MarketCountryNeeds.HasGovernmentMissingGoods)))]"

							using = bg_banner_button_vertical

							blockoverride "banner_button_color" {
								modify_texture = {
									visible = "[And(MarketCountryNeeds.HasBuildingsMissingGoods, Not(MarketCountryNeeds.HasGovernmentMissingGoods))]"
									using = color_yellow_texture
									alpha = 0.6
								}
								modify_texture = {
									visible = "[MarketCountryNeeds.HasGovernmentMissingGoods]"
									using = color_dark_red_texture
								}
							}
							tooltipwidget = {
								using = market_hub_gov_needs_tooltip
							}
						}

						icon = {
							visible = "[And(MarketCountryNeeds.HasPopsMissingGoods, MarketCountryNeeds.HasRebelPopsMissingGoods)]"
							shaderfile = "gfx/FX/pdxgui_default.shader"
							size = {14 14}
							texture = "gfx/interface/icons/alerts_icons/pops_wanting_stuff.dds"

							using = bg_banner_button_vertical

							blockoverride "banner_button_color" {
								modify_texture = {
									using = color_dark_red_texture
								}
							}

							tooltipwidget = {
								using = market_hub_pop_needs_tooltip
							}
						}

						icon = {
							visible = "[Or(Market.HasStarvingProvinces, Market.WillRunOutOfFoodStochpile)]"
							size = {14 14}
							texture = "gfx/interface/icons/location_icons/food.dds"

							using = bg_banner_button_vertical

							blockoverride "banner_button_color" {
								modify_texture = {
									visible = "[And(Not(Market.HasStarvingProvinces), Market.WillRunOutOfFoodStochpile)]"
									using = color_yellow_texture
									alpha = 0.6
								}
								modify_texture = {
									visible = "[Market.HasStarvingProvinces]"
									using = color_dark_red_texture
								}
							}

							tooltipwidget = {
								using = market_food_balance_tooltip
							}
						}
					}
				}

				widget = {
					layoutpolicy_vertical = expanding
					size = { 114 -1 }
					hbox = {
						visible = "[GreaterThan_CFixedPoint(Market.GetTotalMerchantCapacity(Player.Self),'(CFixedPoint)0')]"
						datacontext = "[Market.GetMerchant(Player.Self)]"
						datacontext = "[Player]"
						OutlinerTextBase = {
							minimumsize = { 45 -1 }
							maximumsize = { 45 -1 }
							raw_text = "[Market.GetTotalMerchantCapacity(Player.Self)|1W]@trade_capacity!"
						}
						icon = {
							size = {14 14}
							texture = "gfx/interface/buttons/flats/button_simple.dds"

							modify_texture = {
								using = color_bone_texture
								blend_mode = normal
							}
						}
						OutlinerTextBase = {
							minimumsize = { 55 -1 }
							maximumsize = { 55 -1 }
							raw_text = "[Multiply_CFixedPoint(Merchant.GetTotalTradeProfit, Country.GetModifier('trade_income'))|2+=]@income!"
						}
						tooltipwidget = {
							using = market_hub_trade_tooltip
						}
					}
				}
			}
		}
